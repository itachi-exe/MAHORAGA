# ── Polymarket CLOB credentials ───────────────────────────────────────────
# Get these from https://polymarket.com → Account → API Keys
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# Your Polygon wallet private key (no 0x prefix)
# This is the key that signs and funds orders on-chain
POLY_PRIVATE_KEY=

# Polygon chain — 137 = mainnet, 80002 = Amoy testnet
POLY_CHAIN_ID=137

# ── Betting controls ───────────────────────────────────────────────────────
MAX_BET_USDC=5.0          # Maximum USDC per single bet
MIN_EDGE=0.05             # Minimum probability edge to place a bet (5%)
MIN_CONFIDENCE=0.65       # Minimum model confidence required (65%)

# ── Scheduler ─────────────────────────────────────────────────────────────
SCHEDULE_TIME=20:00       # Daily run time in UTC (HH:MM)
